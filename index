<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ConvênioAuth v3</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>

<style>
/* ═══════════════════════════════════════════════
   TOKENS
═══════════════════════════════════════════════ */
:root {
  --bg:#f0f2f5; --surface:#fff; --surface2:#f7f8fa; --surface3:#eef0f4;
  --border:#e2e5eb; --border2:#cdd1db;
  --ink:#0f1623; --ink2:#374151; --muted:#6b7280; --muted2:#9ca3af;
  --blue:#1a56db; --blue-lt:#eff4ff; --blue-md:#c7d8fc;
  --green:#059669; --green-lt:#ecfdf5; --green-md:#a7f3d0;
  --red:#dc2626; --red-lt:#fef2f2; --red-md:#fecaca;
  --amber:#d97706; --amber-lt:#fffbeb; --amber-md:#fde68a;
  --orange:#ea580c; --orange-lt:#fff7ed; --orange-md:#fed7aa;
  --purple:#7c3aed;
  --radius:8px; --radius-lg:14px;
  --shadow-sm:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shadow:0 4px 6px -1px rgba(0,0,0,.07),0 2px 4px rgba(0,0,0,.04);
  --shadow-lg:0 10px 30px -5px rgba(0,0,0,.1),0 4px 6px rgba(0,0,0,.05);
}
[data-theme="dark"] {
  --bg:#0d0f14; --surface:#141720; --surface2:#1c2030; --surface3:#222840;
  --border:#252a3a; --border2:#323850;
  --ink:#e8ecf5; --ink2:#b0bac8; --muted:#6b7599; --muted2:#4a5170;
  --blue:#4f8fff; --blue-lt:#1a2540; --blue-md:#1e3460;
  --green:#00c980; --green-lt:#0a2520; --green-md:#0f3d28;
  --red:#ff6b6b; --red-lt:#2a1010; --red-md:#3d1515;
  --amber:#ffd166; --amber-lt:#2a2000; --amber-md:#3d3000;
  --orange:#fb923c; --orange-lt:#2a1800; --orange-md:#3d2200;
  --shadow-sm:0 1px 3px rgba(0,0,0,.3);
  --shadow:0 4px 6px rgba(0,0,0,.3);
  --shadow-lg:0 10px 30px rgba(0,0,0,.4);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:14px;scroll-behavior:smooth;}
body{background:var(--bg);color:var(--ink);font-family:'Plus Jakarta Sans',sans-serif;min-height:100vh;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s;}

/* ═══════════════════════════════════════════════
   SETUP SCREEN
═══════════════════════════════════════════════ */
#setup-screen {
  min-height:100vh; display:flex; align-items:center; justify-content:center;
  background:linear-gradient(145deg,#eef2ff 0%,#f0f2f5 50%,#f0fdf4 100%);
}
[data-theme="dark"] #setup-screen {
  background:linear-gradient(145deg,#0d1a35 0%,#0d0f14 50%,#0a1a10 100%);
}
.setup-card {
  background:var(--surface); border:1px solid var(--border); border-radius:20px;
  padding:44px 40px; width:100%; max-width:520px; box-shadow:var(--shadow-lg);
}
.setup-header { text-align:center; margin-bottom:32px; }
.setup-mark {
  width:64px; height:64px; margin:0 auto 16px;
  background:linear-gradient(135deg,var(--blue),#3b82f6);
  border-radius:16px; display:flex; align-items:center; justify-content:center;
  font-size:30px; box-shadow:0 8px 24px rgba(26,86,219,.3);
}
.setup-header h1 { font-family:'Instrument Serif',serif; font-size:26px; color:var(--ink); }
.setup-header p  { font-size:12px; color:var(--muted); margin-top:6px; letter-spacing:.5px; }
.setup-steps { display:flex; flex-direction:column; gap:14px; margin-bottom:28px; }
.step {
  background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius);
  padding:14px 16px; display:flex; gap:12px; align-items:flex-start;
}
.step-num {
  width:26px; height:26px; background:var(--blue); color:#fff;
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:800; flex-shrink:0; margin-top:1px;
}
.step-title { font-size:13px; font-weight:700; color:var(--ink); margin-bottom:4px; }
.step-desc  { font-size:12px; color:var(--muted); line-height:1.6; }
.step-link  { color:var(--blue); font-weight:600; text-decoration:none; }
.step-link:hover { text-decoration:underline; }
.config-area {
  background:var(--surface2); border:1px solid var(--border);
  border-radius:var(--radius-lg); padding:20px; margin-bottom:20px;
}
.config-title { font-size:12px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; margin-bottom:14px; }
.fgroup { margin-bottom:12px; }
.fgroup label { display:block; font-size:10px; font-weight:700; color:var(--ink2); letter-spacing:.5px; text-transform:uppercase; margin-bottom:5px; }
.fgroup input {
  width:100%; background:var(--surface); border:1.5px solid var(--border);
  border-radius:var(--radius); padding:10px 12px; color:var(--ink);
  font-family:'DM Mono',monospace; font-size:12px; outline:none; transition:border-color .15s;
}
.fgroup input:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(26,86,219,.1); }
.btn-primary {
  width:100%; background:var(--blue); border:none; border-radius:var(--radius);
  padding:13px; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:14px;
  font-weight:700; cursor:pointer; transition:filter .15s;
  box-shadow:0 4px 12px rgba(26,86,219,.3); display:flex; align-items:center; justify-content:center; gap:8px;
}
.btn-primary:hover { filter:brightness(1.08); }
.btn-primary:disabled { opacity:.6; cursor:not-allowed; }
.setup-err {
  background:var(--red-lt); border:1px solid var(--red-md); border-radius:var(--radius);
  padding:10px 14px; font-size:12px; color:var(--red); margin-bottom:14px; display:none;
}
.setup-err.on { display:block; }

/* ═══════════════════════════════════════════════
   LOADING
═══════════════════════════════════════════════ */
#loading {
  position:fixed; inset:0; background:var(--bg); z-index:9999;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:18px;
}
.ring { width:48px; height:48px; border:3px solid var(--border); border-top-color:var(--blue); border-radius:50%; animation:spin .75s linear infinite; }
@keyframes spin{to{transform:rotate(360deg)}}
.load-txt { font-size:12px; color:var(--muted); font-family:'DM Mono',monospace; }
.load-sub  { font-size:11px; color:var(--muted2); font-family:'DM Mono',monospace; }

/* ═══════════════════════════════════════════════
   LOGIN
═══════════════════════════════════════════════ */
#login {
  display:none; min-height:100vh; align-items:center; justify-content:center;
  background:var(--bg);
  background-image:radial-gradient(circle at 20% 20%,rgba(26,86,219,.06) 0%,transparent 50%),
                   radial-gradient(circle at 80% 80%,rgba(124,58,237,.04) 0%,transparent 50%);
}
.login-box {
  background:var(--surface); border:1px solid var(--border); border-radius:20px;
  padding:44px 40px; width:100%; max-width:400px; box-shadow:var(--shadow-lg);
}
.login-brand { text-align:center; margin-bottom:32px; }
.login-mark {
  width:56px; height:56px; margin:0 auto 14px;
  background:linear-gradient(135deg,var(--blue),#3b82f6);
  border-radius:14px; display:flex; align-items:center; justify-content:center;
  font-size:26px; box-shadow:0 6px 20px rgba(26,86,219,.3);
}
.login-brand h1 { font-family:'Instrument Serif',serif; font-size:24px; color:var(--ink); }
.login-brand p  { font-size:11px; color:var(--muted); letter-spacing:1px; text-transform:uppercase; margin-top:5px; }
.login-err { background:var(--red-lt); border:1px solid var(--red-md); border-radius:var(--radius); padding:10px 14px; font-size:12px; color:var(--red); margin-bottom:14px; display:none; }
.login-err.on { display:block; }
.field { margin-bottom:16px; }
.field label { display:block; font-size:10px; font-weight:700; color:var(--ink2); letter-spacing:.5px; text-transform:uppercase; margin-bottom:6px; }
.field input {
  width:100%; background:var(--surface2); border:1.5px solid var(--border);
  border-radius:var(--radius); padding:12px 14px; color:var(--ink);
  font-family:'Plus Jakarta Sans',sans-serif; font-size:14px; outline:none; transition:all .15s;
}
.field input:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(26,86,219,.1); }
.login-footer { text-align:center; margin-top:16px; font-size:11px; color:var(--muted); }
.link-setup { color:var(--blue); cursor:pointer; font-weight:600; }
.link-setup:hover { text-decoration:underline; }

/* ═══════════════════════════════════════════════
   APP SHELL
═══════════════════════════════════════════════ */
#app { display:none; }
.topbar {
  background:var(--surface); border-bottom:1px solid var(--border);
  height:58px; padding:0 28px; display:flex; align-items:center; justify-content:space-between;
  position:sticky; top:0; z-index:100; box-shadow:var(--shadow-sm); transition:background .3s,border-color .3s;
}
.brand { display:flex; align-items:center; gap:10px; }
.brand-mark { width:32px; height:32px; background:linear-gradient(135deg,var(--blue),#3b82f6); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; box-shadow:0 2px 8px rgba(26,86,219,.25); }
.brand-name { font-family:'Instrument Serif',serif; font-size:17px; color:var(--ink); }
.brand-ver  { font-size:10px; color:var(--muted); font-family:'DM Mono',monospace; margin-left:2px; }
.topbar-right { display:flex; align-items:center; gap:8px; }
.stat-pills { display:flex; gap:8px; }
.stat-pill { background:var(--surface2); border:1px solid var(--border); border-radius:20px; padding:4px 12px; font-size:11px; font-weight:600; display:flex; align-items:center; gap:6px; color:var(--ink2); transition:all .15s; }
.stat-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.stat-pill.click { cursor:pointer; }
.stat-pill.click:hover { border-color:var(--blue); color:var(--blue); }
.online-dot { width:8px; height:8px; border-radius:50%; background:#22c55e; box-shadow:0 0 0 2px rgba(34,197,94,.3); animation:pulse 2s infinite; }
.offline-dot { width:8px; height:8px; border-radius:50%; background:var(--red); }
@keyframes pulse{0%,100%{box-shadow:0 0 0 2px rgba(34,197,94,.3)}50%{box-shadow:0 0 0 4px rgba(34,197,94,.1)}}
.theme-btn { width:34px; height:34px; background:var(--surface2); border:1px solid var(--border); border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:16px; transition:all .15s; }
.theme-btn:hover { border-color:var(--blue); }
.user-chip { background:var(--blue-lt); border:1px solid var(--blue-md); border-radius:20px; padding:5px 14px; font-size:12px; font-weight:700; color:var(--blue); display:flex; align-items:center; gap:7px; }
.role-tag { font-size:9px; font-family:'DM Mono',monospace; background:var(--blue); color:#fff; border-radius:4px; padding:1px 6px; letter-spacing:.4px; text-transform:uppercase; }
.role-tag.admin { background:var(--purple); }
.btn-ico { background:none; border:1.5px solid var(--border); border-radius:8px; padding:6px 12px; color:var(--muted); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:600; cursor:pointer; transition:all .15s; white-space:nowrap; }
.btn-ico:hover { border-color:var(--border2); color:var(--ink); }
.btn-ico.blue:hover  { border-color:var(--blue);  color:var(--blue); }
.btn-ico.green:hover { border-color:var(--green); color:var(--green); }
.btn-ico.red:hover   { border-color:var(--red);   color:var(--red); }

/* TABBAR */
.tabbar { background:var(--surface); border-bottom:1px solid var(--border); padding:0 28px; display:flex; overflow-x:auto; gap:2px; transition:background .3s; }
.tabbar::-webkit-scrollbar{height:3px;} .tabbar::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.tab-item { padding:13px 16px; font-size:12px; font-weight:600; cursor:pointer; border-bottom:2px solid transparent; color:var(--muted); white-space:nowrap; transition:all .15s; user-select:none; display:flex; align-items:center; gap:6px; }
.tab-item:hover { color:var(--ink); }
.tab-item.active { color:var(--blue); border-bottom-color:var(--blue); }
.tab-count { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:1px 7px; font-size:10px; font-family:'DM Mono',monospace; color:var(--muted); transition:all .15s; }
.tab-item.active .tab-count { background:var(--blue-lt); border-color:var(--blue-md); color:var(--blue); }
.tab-urg .tab-count  { background:var(--red-lt);   border-color:var(--red-md);   color:var(--red); }
.tab-arch .tab-count { background:var(--green-lt); border-color:var(--green-md); color:var(--green); }

main { max-width:1440px; margin:0 auto; padding:24px 28px; }

/* PAGE HEADER */
.page-hd { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:20px; gap:12px; }
.page-hd h2 { font-family:'Instrument Serif',serif; font-size:22px; color:var(--ink); }
.page-hd p  { font-size:12px; color:var(--muted); margin-top:3px; }

/* TOOLBAR */
.toolbar { display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:14px; }
.search-box { flex:1; min-width:220px; position:relative; }
.search-box input { width:100%; background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius); padding:9px 14px 9px 38px; color:var(--ink); font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; outline:none; transition:all .15s; }
.search-box input::placeholder { color:var(--muted); }
.search-box input:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(26,86,219,.08); }
.s-ico { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted2); font-size:14px; pointer-events:none; }
.filter-btn { background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius); padding:8px 14px; color:var(--ink2); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:600; cursor:pointer; transition:all .15s; white-space:nowrap; }
.filter-btn:hover { border-color:var(--border2); }
.fb-all  { background:var(--ink)!important;       border-color:var(--ink)!important;       color:#fff!important; }
.fb-ana  { background:var(--amber-lt)!important;  border-color:var(--amber-md)!important;  color:var(--amber)!important; }
.fb-exi  { background:var(--orange-lt)!important; border-color:var(--orange-md)!important; color:var(--orange)!important; }
.fb-neg  { background:var(--red-lt)!important;    border-color:var(--red-md)!important;    color:var(--red)!important; }
.btn-add { background:var(--blue); border:none; border-radius:var(--radius); padding:9px 16px; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:6px; white-space:nowrap; transition:filter .15s; box-shadow:0 2px 8px rgba(26,86,219,.25); }
.btn-add:hover { filter:brightness(1.08); }
.btn-add.green { background:var(--green); box-shadow:0 2px 8px rgba(5,150,105,.25); }

/* CONV BAR */
.conv-bar { display:flex; gap:6px; flex-wrap:wrap; align-items:center; padding:10px 14px; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); margin-bottom:14px; }
.conv-lbl { font-size:10px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; margin-right:2px; white-space:nowrap; }
.conv-pill { background:var(--surface2); border:1.5px solid var(--border); border-radius:20px; padding:3px 12px; font-size:11px; font-weight:600; color:var(--muted); cursor:pointer; transition:all .15s; font-family:'Plus Jakarta Sans',sans-serif; }
.conv-pill:hover { border-color:var(--border2); color:var(--ink); }
.conv-pill.on { background:var(--ink); border-color:var(--ink); color:#fff; }

/* TABLE */
.card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); transition:background .3s,border-color .3s; }
table { width:100%; border-collapse:collapse; }
thead tr { background:var(--surface2); border-bottom:1px solid var(--border); }
th { padding:12px 16px; text-align:left; font-size:10px; font-weight:700; color:var(--muted); letter-spacing:.8px; text-transform:uppercase; white-space:nowrap; cursor:pointer; user-select:none; transition:color .15s; }
th:hover { color:var(--ink2); }
.sa { margin-left:3px; opacity:.3; font-size:9px; }
.sa.on { opacity:1; color:var(--blue); }
tbody tr { border-bottom:1px solid var(--border); transition:background .12s; }
tbody tr:last-child { border-bottom:none; }
tbody tr:hover { background:var(--surface2); }
td { padding:14px 16px; font-size:13px; vertical-align:middle; }

/* ROW STATUS */
tr.rs-ana { background:var(--amber-lt)!important; } tr.rs-ana:hover { background:#fef3c7!important; }
tr.rs-exi { background:var(--orange-lt)!important;} tr.rs-exi:hover { background:#ffedd5!important; }
tr.rs-neg { background:var(--red-lt)!important;   } tr.rs-neg:hover { background:#fee2e2!important; }
tr.rs-urg { background:#fff1f2!important; } tr.rs-vec { background:#ffe4e4!important; }

/* BADGES */
.badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:10px; font-weight:700; white-space:nowrap; }
.b-ana { background:var(--amber-lt);  color:var(--amber);  border:1px solid var(--amber-md); }
.b-exi { background:var(--orange-lt); color:var(--orange); border:1px solid var(--orange-md); }
.b-neg { background:var(--red-lt);    color:var(--red);    border:1px solid var(--red-md); }
.b-aut { background:var(--green-lt);  color:var(--green);  border:1px solid var(--green-md); }
.b-arq { background:var(--surface2);  color:var(--muted);  border:1px solid var(--border); }

/* PRAZO */
.pb { display:inline-flex; align-items:center; gap:4px; padding:3px 9px; border-radius:20px; font-size:10px; font-weight:700; font-family:'DM Mono',monospace; white-space:nowrap; }
.pb-ok  { background:var(--green-lt); color:#065f46; border:1px solid var(--green-md); }
.pb-alt { background:var(--amber-lt); color:#78350f; border:1px solid var(--amber-md); }
.pb-urg { background:var(--red-lt);   color:#991b1b; border:1px solid var(--red-md); }
.pb-vec { background:#fecaca; color:#7f1d1d; border:1px solid #f87171; }
.pb-sem { color:var(--muted2); font-size:11px; font-family:'DM Mono',monospace; }

/* CONVÊNIO */
.cv { font-family:'Plus Jakarta Sans',sans-serif; font-weight:800; font-size:12px; white-space:nowrap; }
.cv-amil{color:#1a56db;} .cv-asfeb{color:#1a2e6b;} .cv-bradesco{color:#cc0000;}
.cv-cassi{color:#005ca8;} .cv-geap{color:#007a3d;} .cv-planserv{color:#1f3c88;}
.cv-plansul{color:#005baa;} .cv-postal{color:#b45309;} .cv-promedica{color:#1a7c3e;}
.cv-select{color:#c45f00;} .cv-sulamerica{color:#c44f00;} .cv-unimed{color:#006b33;}
.cv-uniaomedica{color:#003f9e;} .cv-vitallis{color:#6b21a8;} .cv-outro{color:var(--muted);}

/* CELLS */
.num { font-family:'DM Mono',monospace; font-size:12px; color:var(--blue); font-weight:500; }
.nome-c { font-weight:600; color:var(--ink); }
.obs-c  { font-size:11px; color:var(--muted); max-width:130px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.rastr  { font-size:10px; line-height:1.6; }
.r-lbl  { font-weight:700; text-transform:uppercase; letter-spacing:.4px; font-size:9px; }
.r-cri  { color:var(--green); } .r-edi { color:var(--amber); }
.r-who  { font-weight:600; color:var(--ink2); font-size:11px; }
.r-dt   { color:var(--muted); font-family:'DM Mono',monospace; font-size:10px; }

/* AÇÕES */
.acts { display:flex; gap:5px; }
.act { background:none; border:1.5px solid var(--border); border-radius:6px; padding:4px 9px; color:var(--muted); cursor:pointer; font-size:12px; transition:all .15s; }
.act:hover        { border-color:var(--blue);  color:var(--blue);  background:var(--blue-lt); }
.act.danger:hover { border-color:var(--red);   color:var(--red);   background:var(--red-lt); }
.act.ok:hover     { border-color:var(--green); color:var(--green); background:var(--green-lt); }

/* TABLE FOOTER */
.tfoot { display:flex; align-items:center; justify-content:space-between; padding:11px 16px; border-top:1px solid var(--border); background:var(--surface2); font-size:11px; color:var(--muted); transition:background .3s; }
.btn-csv { background:none; border:1.5px solid var(--border); border-radius:6px; padding:4px 12px; color:var(--muted); font-family:'Plus Jakarta Sans',sans-serif; font-size:11px; font-weight:600; cursor:pointer; transition:all .15s; }
.btn-csv:hover { border-color:var(--green); color:var(--green); }

/* EMPTY */
.empty { text-align:center; padding:56px 20px; color:var(--muted); }
.empty-ico { font-size:36px; margin-bottom:10px; opacity:.5; }

/* BANNERS */
.banner { border-radius:var(--radius-lg); padding:16px 20px; margin-bottom:20px; display:flex; align-items:center; gap:14px; }
.bn-urg  { background:var(--red-lt);   border:1px solid var(--red-md); }
.bn-arch { background:var(--green-lt); border:1px solid var(--green-md); }
.bn-uni  { background:var(--blue-lt);  border:1px solid var(--blue-md); }
.bn-ico  { font-size:28px; }
.bn-title{ font-family:'Instrument Serif',serif; font-size:17px; }
.bn-urg .bn-title  { color:#9f1239; } .bn-arch .bn-title { color:#065f46; } .bn-uni .bn-title { color:var(--blue); }
.bn-sub  { font-size:12px; color:var(--muted); margin-top:2px; }
.bn-cnt  { margin-left:auto; border-radius:20px; padding:4px 14px; font-size:12px; font-weight:800; color:#fff; white-space:nowrap; }
.bn-urg .bn-cnt { background:var(--red); } .bn-arch .bn-cnt { background:var(--green); } .bn-uni .bn-cnt { background:var(--blue); }
.mes-lbl { font-size:11px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; font-family:'DM Mono',monospace; padding:6px 12px; background:var(--surface2); border-radius:6px; display:inline-block; margin:18px 0 8px; }

/* ADM */
.adm-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
@media(max-width:900px){.adm-grid{grid-template-columns:1fr;}}
.adm-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); }
.adm-hd { background:var(--surface2); border-bottom:1px solid var(--border); padding:14px 18px; display:flex; align-items:center; justify-content:space-between; }
.adm-hd-t { font-size:13px; font-weight:700; color:var(--ink); }
.adm-body { padding:18px; }
.user-list { display:flex; flex-direction:column; gap:10px; }
.user-item { background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:12px 14px; display:flex; align-items:center; justify-content:space-between; }
.u-left { display:flex; align-items:center; gap:10px; }
.u-av { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:800; }
.u-name  { font-size:13px; font-weight:700; color:var(--ink); }
.u-login { font-size:11px; color:var(--muted); font-family:'DM Mono',monospace; margin-top:1px; }
.rc { font-size:9px; border-radius:5px; padding:2px 8px; font-weight:800; text-transform:uppercase; letter-spacing:.4px; }
.rc-adm { background:var(--purple); color:#fff; }
.rc-usr { background:var(--blue-lt); color:var(--blue); border:1px solid var(--blue-md); }
.audit-feed { display:flex; flex-direction:column; gap:8px; max-height:400px; overflow-y:auto; }
.ae { background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:10px 13px; }
.ae-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
.ae-lbl { font-size:11px; font-weight:700; }
.ae-cre { color:var(--green); } .ae-edi { color:var(--amber); } .ae-del { color:var(--red); } .ae-log { color:var(--blue); }
.ae-ts  { font-size:10px; color:var(--muted); font-family:'DM Mono',monospace; }
.ae-desc{ font-size:11px; color:var(--ink2); }
.ae-desc b { color:var(--ink); }
.dz { margin-top:18px; padding-top:16px; border-top:1px solid var(--red-md); }
.dz-lbl { font-size:10px; font-weight:700; color:var(--red); text-transform:uppercase; letter-spacing:.8px; margin-bottom:10px; }
.btn-dng { background:none; border:1.5px solid var(--red-md); border-radius:var(--radius); padding:8px 16px; color:var(--red); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:700; cursor:pointer; transition:all .15s; display:flex; align-items:center; gap:6px; }
.btn-dng:hover { background:var(--red-lt); }

/* BACKUP */
.backup-box { background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:14px; margin-top:14px; }
.backup-lbl { font-size:10px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; margin-bottom:10px; }
.backup-acts { display:flex; gap:8px; flex-wrap:wrap; }
.btn-backup { background:none; border:1.5px solid var(--border); border-radius:var(--radius); padding:8px 14px; color:var(--ink2); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:600; cursor:pointer; transition:all .15s; display:flex; align-items:center; gap:6px; }
.btn-backup:hover { border-color:var(--blue); color:var(--blue); background:var(--blue-lt); }
.btn-backup.imp:hover { border-color:var(--green); color:var(--green); background:var(--green-lt); }
#import-file { display:none; }

/* MODAIS */
.overlay { display:none; position:fixed; inset:0; background:rgba(15,22,35,.45); z-index:200; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
.overlay.on { display:flex; }
.modal { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); padding:30px; width:100%; max-width:520px; animation:mup .2s ease; max-height:90vh; overflow-y:auto; box-shadow:var(--shadow-lg); transition:background .3s; }
.modal.sm { max-width:420px; }
@keyframes mup{from{transform:translateY(14px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal h3 { font-family:'Instrument Serif',serif; font-size:20px; color:var(--ink); margin-bottom:22px; }
.frow { display:flex; gap:12px; }
.fg { margin-bottom:14px; flex:1; }
.fg label { display:block; font-size:10px; font-weight:700; color:var(--ink2); letter-spacing:.5px; text-transform:uppercase; margin-bottom:6px; }
.fg input, .fg select { width:100%; background:var(--surface2); border:1.5px solid var(--border); border-radius:var(--radius); padding:10px 12px; color:var(--ink); font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; outline:none; transition:all .15s; appearance:none; }
.fg input:focus, .fg select:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(26,86,219,.08); }
.fg select option { background:var(--surface); color:var(--ink); }
.modal-foot { display:flex; gap:10px; margin-top:22px; }
.btn-cancel { flex:1; background:none; border:1.5px solid var(--border); border-radius:var(--radius); padding:11px; color:var(--muted); font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:600; cursor:pointer; transition:all .15s; }
.btn-cancel:hover { border-color:var(--border2); color:var(--ink); background:var(--surface2); }
.btn-ok { flex:2; background:var(--blue); border:none; border-radius:var(--radius); padding:11px; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:700; cursor:pointer; transition:filter .15s; display:flex; align-items:center; justify-content:center; gap:8px; box-shadow:0 2px 8px rgba(26,86,219,.25); }
.btn-ok:hover { filter:brightness(1.08); }
.btn-ok:disabled { opacity:.6; cursor:not-allowed; }
.btn-ok.green { background:var(--green); box-shadow:0 2px 8px rgba(5,150,105,.25); }

/* DESTROY */
.dcard { background:var(--surface); border-radius:20px; padding:38px; width:100%; max-width:420px; text-align:center; box-shadow:var(--shadow-lg); }
.d-ico   { font-size:52px; margin-bottom:14px; }
.d-title { font-family:'Instrument Serif',serif; font-size:22px; color:#7f1d1d; margin-bottom:8px; }
.d-sub   { font-size:13px; color:var(--muted); line-height:1.7; margin-bottom:22px; }
.d-input { width:100%; background:var(--surface2); border:1.5px solid var(--red-md); border-radius:var(--radius); padding:12px; color:var(--ink); font-family:'Plus Jakarta Sans',sans-serif; font-size:15px; outline:none; text-align:center; letter-spacing:3px; margin-bottom:10px; transition:border-color .15s; }
.d-input:focus { border-color:var(--red); }
.d-err { font-size:12px; color:var(--red); margin-bottom:14px; display:none; }
.d-err.on { display:block; }
.d-foot { display:flex; gap:10px; }
.btn-dest { flex:1; background:var(--red); border:none; border-radius:var(--radius); padding:12px; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:700; cursor:pointer; transition:filter .15s; }
.btn-dest:hover { filter:brightness(1.1); }

/* ENCERRAMENTO */
#enc { display:none; position:fixed; inset:0; background:var(--bg); z-index:99999; align-items:center; justify-content:center; flex-direction:column; gap:18px; text-align:center; }
.enc-ico   { font-size:72px; }
.enc-line  { width:50px; height:3px; background:var(--border); border-radius:2px; }
.enc-title { font-family:'Instrument Serif',serif; font-size:32px; color:var(--ink); }
.enc-sub   { font-size:14px; color:var(--muted); max-width:360px; line-height:1.8; }

/* GLOBAL SEARCH */
.gs-list { max-height:380px; overflow-y:auto; }
.gs-item { padding:12px 16px; border-bottom:1px solid var(--border); cursor:pointer; transition:background .12s; display:flex; align-items:center; gap:12px; }
.gs-item:last-child { border-bottom:none; }
.gs-item:hover { background:var(--surface2); }
.gs-tab  { font-size:10px; color:var(--muted); font-family:'DM Mono',monospace; min-width:80px; }
.gs-nome { font-weight:600; font-size:13px; color:var(--ink); }
.gs-reg  { font-family:'DM Mono',monospace; font-size:11px; color:var(--blue); }

/* HIST */
.hist-feed { display:flex; flex-direction:column; gap:8px; max-height:360px; overflow-y:auto; }
.hi { background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius); padding:11px 13px; }
.hi-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
.hi-ev  { font-size:11px; font-weight:700; }
.hi-cre { color:var(--green); } .hi-edi { color:var(--amber); } .hi-del { color:var(--red); }
.hi-ts  { font-size:10px; color:var(--muted); font-family:'DM Mono',monospace; }
.hi-desc{ font-size:11px; color:var(--ink2); }

/* REALTIME INDICATOR */
.rt-badge { display:inline-flex; align-items:center; gap:5px; font-size:11px; color:var(--muted); }

/* TOAST */
.toast { position:fixed; bottom:22px; right:22px; background:var(--ink); border-radius:var(--radius); padding:12px 18px; font-size:12px; font-weight:600; color:var(--bg); z-index:9998; transform:translateY(70px); opacity:0; transition:all .3s cubic-bezier(.34,1.56,.64,1); box-shadow:var(--shadow-lg); max-width:300px; }
.toast.on  { transform:translateY(0); opacity:1; }
.toast.err { background:var(--red); color:#fff; }

@media(max-width:768px){
  .topbar{padding:0 14px;} .stat-pills{display:none;} main{padding:14px;} .tabbar{padding:0 14px;}
  .frow{flex-direction:column;} th,td{padding:10px 12px;} .adm-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- LOADING -->
<div id="loading">
  <div class="ring"></div>
  <div class="load-txt" id="load-txt">Conectando ao Firebase...</div>
  <div class="load-sub" id="load-sub"></div>
</div>

<!-- SETUP -->
<div id="setup-screen" style="display:none">
  <div class="setup-card">
    <div class="setup-header">
      <div class="setup-mark">🏥</div>
      <h1>ConvênioAuth v3</h1>
      <p>Configure o Firebase para começar</p>
    </div>
    <div class="setup-steps">
      <div class="step">
        <div class="step-num">1</div>
        <div>
          <div class="step-title">Acesse o Firebase Console</div>
          <div class="step-desc">Vá em <a class="step-link" href="https://console.firebase.google.com" target="_blank">console.firebase.google.com</a> → Criar projeto → dê um nome (ex: convenioauth)</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div>
          <div class="step-title">Ative o Firestore</div>
          <div class="step-desc">No menu lateral → Build → Firestore Database → Criar banco de dados → Modo de produção → Escolha a região <b>southamerica-east1</b></div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div>
          <div class="step-title">Configure as regras do Firestore</div>
          <div class="step-desc">Firestore → Regras → substitua pelo código abaixo e publique:<br><code style="font-family:'DM Mono',monospace;font-size:11px;background:var(--surface2);padding:2px 6px;border-radius:4px">rules_version = '2'; service cloud.firestore { match /databases/{db}/documents { match /{doc=**} { allow read, write: if true; } } }</code></div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div>
          <div class="step-title">Copie as credenciais</div>
          <div class="step-desc">Configurações do projeto (⚙️) → Seus aplicativos → Adicionar app (Web &lt;/&gt;) → Registrar → Copie os dados do <b>firebaseConfig</b></div>
        </div>
      </div>
    </div>
    <div class="setup-err" id="setup-err"></div>
    <div class="config-area">
      <div class="config-title">Credenciais do Firebase</div>
      <div class="fgroup"><label>API Key</label><input type="text" id="cfg-apiKey" placeholder="AIzaSy..."></div>
      <div class="fgroup"><label>Auth Domain</label><input type="text" id="cfg-authDomain" placeholder="seu-projeto.firebaseapp.com"></div>
      <div class="fgroup"><label>Project ID</label><input type="text" id="cfg-projectId" placeholder="seu-projeto"></div>
      <div class="fgroup"><label>Storage Bucket</label><input type="text" id="cfg-storageBucket" placeholder="seu-projeto.appspot.com"></div>
      <div class="fgroup"><label>Messaging Sender ID</label><input type="text" id="cfg-messagingSenderId" placeholder="123456789"></div>
      <div class="fgroup"><label>App ID</label><input type="text" id="cfg-appId" placeholder="1:123456789:web:abc123"></div>
    </div>
    <button class="btn-primary" id="btn-setup" onclick="saveConfig()">🔥 Conectar ao Firebase</button>
  </div>
</div>

<!-- LOGIN -->
<div id="login">
  <div class="login-box">
    <div class="login-brand">
      <div class="login-mark">🏥</div>
      <h1>ConvênioAuth</h1>
      <p>Sistema de Autorizações v3</p>
    </div>
    <div class="login-err" id="login-err"></div>
    <div class="field"><label>Usuário</label><input type="text" id="f-login" placeholder="seu.login" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <div class="field"><label>Senha</label><input type="password" id="f-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="btn-primary" id="btn-login" onclick="doLogin()">Entrar no sistema</button>
    <div class="login-footer"><span class="link-setup" onclick="showSetup()">⚙ Reconfigurar Firebase</span></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="brand">
      <div class="brand-mark">🏥</div>
      <span class="brand-name">ConvênioAuth</span>
      <span class="brand-ver">v3</span>
    </div>
    <div class="topbar-right">
      <div class="stat-pills">
        <div class="stat-pill"><div class="stat-dot" style="background:var(--amber)"></div><span id="st-ana">0</span> Análise</div>
        <div class="stat-pill"><div class="stat-dot" style="background:var(--orange)"></div><span id="st-exi">0</span> Exigência</div>
        <div class="stat-pill"><div class="stat-dot" style="background:var(--red)"></div><span id="st-neg">0</span> Negadas</div>
        <div class="stat-pill"><div class="stat-dot" style="background:var(--blue)"></div><span id="st-tot">0</span> Total</div>
        <div class="stat-pill click" onclick="goTab('🚨 Urgentes')"><div class="stat-dot" style="background:var(--red)"></div><span id="st-urg">0</span> Urgentes</div>
        <div class="stat-pill click" onclick="goTab('✅ Arquivados')"><div class="stat-dot" style="background:var(--green)"></div><span id="st-arq">0</span> Arquivados</div>
      </div>
      <div class="rt-badge" id="rt-badge"><div class="online-dot"></div>Tempo real</div>
      <button class="theme-btn" onclick="toggleTheme()" id="theme-btn">🌙</button>
      <button class="btn-ico blue" onclick="openGS()">🔍 Busca</button>
      <button class="btn-ico" onclick="openBackup()">💾 Backup</button>
      <div class="user-chip"><span id="chip-name">—</span><span class="role-tag" id="chip-role">user</span></div>
      <button class="btn-ico red" onclick="doLogout()">Sair</button>
    </div>
  </div>
  <div class="tabbar" id="tabbar"></div>
  <main id="main"></main>
</div>

<!-- MODAL AUTORIZAÇÃO -->
<div class="overlay" id="m-auth">
  <div class="modal">
    <h3 id="m-auth-t">Nova Autorização</h3>
    <div class="frow">
      <div class="fg"><label>Nº Registro *</label><input type="text" id="fa-reg" placeholder="Ex: 3784645"></div>
      <div class="fg"><label>Nº Guia</label><input type="text" id="fa-guia" placeholder="Ex: 7165195"></div>
    </div>
    <div class="frow">
      <div class="fg"><label>Status *</label>
        <select id="fa-st">
          <option value="">— Selecione —</option>
          <option value="Análise">Em Análise</option>
          <option value="Exigência">Exigência</option>
          <option value="Autorizado">Autorizado</option>
          <option value="Arquivado">Arquivado</option>
          <option value="Negada">Negada</option>
        </select>
      </div>
      <div class="fg"><label>Convênio *</label>
        <select id="fa-cv">
          <option value="">— Selecione —</option>
          <option value="Amil">Amil</option>
          <option value="Asfeb">Asfeb</option>
          <option value="Bradesco">Bradesco</option>
          <option value="Cassi">Cassi</option>
          <option value="Geap">Geap</option>
          <option value="Planserv">Planserv</option>
          <option value="Plansul">Plansul</option>
          <option value="Postal Saúde">Postal Saúde</option>
          <option value="Promédica">Promédica</option>
          <option value="SelectSaúde">SelectSaúde</option>
          <option value="SulAmérica">SulAmérica</option>
          <option value="União Médica">União Médica</option>
          <option value="Unimed">Unimed</option>
          <option value="Vitallis">Vitallis</option>
        </select>
      </div>
    </div>
    <div class="fg"><label>Nome do Paciente *</label><input type="text" id="fa-nome" placeholder="Nome completo"></div>
    <div class="fg"><label>Observação / Contato</label><input type="text" id="fa-obs" placeholder="Telefone, e-mail ou observação"></div>
    <div class="modal-foot">
      <button class="btn-cancel" onclick="closeAll()">Cancelar</button>
      <button class="btn-ok" id="btn-sa" onclick="saveAuth()">💾 Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL UNIMED -->
<div class="overlay" id="m-uni">
  <div class="modal sm">
    <h3 id="m-uni-t">Adicionar Paciente Unimed</h3>
    <div class="fg"><label>Nome do Paciente *</label><input type="text" id="fu-nome" placeholder="Nome completo"></div>
    <div class="frow">
      <div class="fg"><label>Data Agendada</label><input type="date" id="fu-data"></div>
      <div class="fg"><label>Telefone</label><input type="text" id="fu-tel" placeholder="77 99999-9999"></div>
    </div>
    <div class="modal-foot">
      <button class="btn-cancel" onclick="closeAll()">Cancelar</button>
      <button class="btn-ok green" id="btn-su" onclick="saveUnimed()">💾 Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL USUÁRIO -->
<div class="overlay" id="m-user">
  <div class="modal sm">
    <h3 id="m-user-t">Novo Usuário</h3>
    <div class="frow">
      <div class="fg"><label>Nome Completo *</label><input type="text" id="fu-name" placeholder="Ex: Maria Silva"></div>
      <div class="fg"><label>Login *</label><input type="text" id="fu-login" placeholder="Ex: maria"></div>
    </div>
    <div class="frow">
      <div class="fg"><label>Senha *</label><input type="password" id="fu-pass" placeholder="mínimo 6 caracteres"></div>
      <div class="fg"><label>Perfil</label>
        <select id="fu-role"><option value="user">Usuário</option><option value="admin">Administrador</option></select>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn-cancel" onclick="closeAll()">Cancelar</button>
      <button class="btn-ok" id="btn-uu" onclick="saveUser()">💾 Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL BUSCA GLOBAL -->
<div class="overlay" id="m-gs">
  <div class="modal">
    <h3>🔍 Busca Global</h3>
    <div class="fg"><input type="text" id="gs-q" placeholder="Buscar em todos os meses..." oninput="runGS(this.value)" autocomplete="off"></div>
    <div class="gs-list" id="gs-res"><div class="empty"><div class="empty-ico">🔎</div><div>Digite para buscar</div></div></div>
    <div class="modal-foot" style="margin-top:14px"><button class="btn-cancel" style="flex:1" onclick="closeAll()">Fechar</button></div>
  </div>
</div>

<!-- MODAL HISTÓRICO -->
<div class="overlay" id="m-hist">
  <div class="modal">
    <h3>📋 Histórico do Registro</h3>
    <div class="hist-feed" id="hist-c"></div>
    <div class="modal-foot" style="margin-top:14px"><button class="btn-cancel" style="flex:1" onclick="closeAll()">Fechar</button></div>
  </div>
</div>

<!-- MODAL BACKUP -->
<div class="overlay" id="m-backup">
  <div class="modal sm">
    <h3>💾 Backup & Restauração</h3>
    <p style="font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6">Exporte todos os dados para um arquivo JSON ou importe um backup anterior.</p>
    <div style="display:flex;flex-direction:column;gap:10px">
      <button class="btn-ok" onclick="exportBackup()">📤 Exportar Backup (JSON)</button>
      <button class="btn-ok green" onclick="document.getElementById('import-file').click()">📥 Importar Backup</button>
      <input type="file" id="import-file" accept=".json" onchange="importBackup(this)">
    </div>
    <div class="modal-foot" style="margin-top:16px"><button class="btn-cancel" style="flex:1" onclick="closeAll()">Fechar</button></div>
  </div>
</div>

