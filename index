}

async function saveUser() {
  const fullname=v('fu-name'),login=v('fu-login'),password=v('fu-pass'),role=v('fu-role');
  if(!fullname||!login||!password){toast('Preencha todos os campos',true);return;}
  if(password.length<6){toast('Senha mínimo 6 caracteres',true);return;}
  setBL('btn-uu',true);
  const isNew=!editUserId; const id=editUserId||String(nextId++);
  const colors=['#1a56db','#7c3aed','#059669','#dc2626','#d97706','#0891b2'];
  const color=(USERS.find(x=>String(x.id)===String(editUserId))||{}).color||colors[USERS.length%colors.length];
  const record={id,fullname,login,password,role,color,createdAt:isNew?nowStr():(USERS.find(x=>String(x.id)===String(editUserId))||{}).createdAt||nowStr()};
  if(isNew&&USERS.find(u=>u.login===login)){toast('Login já existe!',true);setBL('btn-uu',false,'💾 Salvar');return;}
  closeAll();
  try{await fbSaveUser(record);await pushAudit(isNew?'create':'edit',`${isNew?'Criou':'Editou'} usuário @${login} (${role})`);toast(isNew?'✅ Usuário criado':'✅ Usuário atualizado');}
  catch(e){toast('Erro: '+e.message,true);}
  finally{setBL('btn-uu',false,'💾 Salvar');}
}

