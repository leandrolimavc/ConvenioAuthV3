  const rec={...r,status:'Arquivado',editedBy:currentUser.login,editedAt:nowStr()};
  try{await fbSaveAuth(currentTab,rec);await pushAudit('edit',`Arquivou reg. ${r.registro} — ${r.nome}`);toast('📁 Registro arquivado');}
  catch(e){toast('Erro: '+e.message,true);}
}
async function reabrir(tab,id){
  const r=(DB[tab]||[]).find(x=>String(x.id)===String(id)); if(!r)return;
  const rec={...r,status:'Análise',editedBy:currentUser.login,editedAt:nowStr()};
  try{await fbSaveAuth(tab,rec);await pushAudit('edit',`Reabriu reg. ${r.registro} — ${r.nome}`);toast('↩ Registro reaberto para Em Análise');}
  catch(e){toast('Erro: '+e.message,true);}
}
async function delArquivado(tab,id){
  if(!confirm('Excluir permanentemente?'))return;
  const r=(DB[tab]||[]).find(x=>String(x.id)===String(id));
  try{await fbDeleteAuth(tab,id);await pushAudit('delete',`Excluiu arquivado ${r?.registro||id}`);toast('🗑 Registro excluído');}
  catch(e){toast('Erro: '+e.message,true);}
}

// DESTRUIÇÃO
async function confirmDestroy(){
  const pass=document.getElementById('d-pass').value;
  if(pass!==DESTROY_PASS){document.getElementById('d-err').classList.add('on');s2('d-pass','');return;}
  closeAll();
  try{await fbSetConfig('status','inativo');}catch(e){}
  showEncerramento();
}
function showEncerramento(){
  stopListeners();
  ['loading','login','app'].forEach(hide);
  show('enc','flex');
}

// BUSCA GLOBAL
function runGS(q){
  q=q.toLowerCase().trim();
  const res=document.getElementById('gs-res');
  if(!q){res.innerHTML='<div class="empty"><div class="empty-ico">🔎</div><div>Digite algo para buscar</div></div>';return;}
  const found=[];
  Object.entries(DB).forEach(([tab,rows])=>{
    (rows||[]).forEach(r=>{
      if((r.registro||'').includes(q)||(r.nome||'').toLowerCase().includes(q)||(r.convenio||'').toLowerCase().includes(q)||(r.guia||'').includes(q)||(r.obs||'').toLowerCase().includes(q))
        found.push({...r,_tab:tab});
    });
  });
  if(!found.length){res.innerHTML='<div class="empty"><div class="empty-ico">🔎</div><div>Nenhum resultado</div></div>';return;}
  res.innerHTML=`<div class="gs-list">${found.slice(0,40).map(r=>`
    <div class="gs-item" onclick="jumpTo('${r._tab}','${r.id}')">
      <span class="gs-tab">${getMesLabel(r._tab)}</span>
      ${cv(r.convenio)}
      <div style="flex:1"><div class="gs-nome">${r.nome}</div><div style="display:flex;gap:8px;margin-top:2px"><span class="gs-reg">${r.registro}</span>${badge(r.status)}</div></div>
    </div>`).join('')}</div>`;
}
function jumpTo(tab,id){
  closeAll();
  currentTab=tab;currentFilter='all';currentConv='Todos';sortKey='';sortDir=1;
  buildTabs();render();
  setTimeout(()=>{
    document.querySelectorAll('#tbody tr').forEach(tr=>{
      if(tr.innerHTML.includes(id)){
        tr.style.background='rgba(26,86,219,.12)';
        tr.scrollIntoView({behavior:'smooth',block:'center'});
        setTimeout(()=>tr.style.background='',2500);
      }
    });
  },300);
}

// HISTÓRICO
function openHist(id){
  const reg=Object.values(DB).flat().find(r=>String(r.id)===String(id));
  const hist=HISTORY[id]||[];
  const auditE=AUDIT.filter(a=>(a.detail||'').includes(reg?.registro||'__'))
    .map(a=>({action:a.action,user:a.user,login:a.login,timestamp:a.timestamp,detail:a.detail}));
  const all=[...hist,...auditE].sort((a,b)=>(b.timestamp||'').localeCompare(a.timestamp||''));
  const items=all.length?all:[
    reg?.editedBy?{action:'edit',user:reg.editedBy,timestamp:reg.editedAt,detail:'Última edição'}:null,
    reg?.createdBy?{action:'create',user:reg.createdBy,timestamp:reg.createdAt||'—',detail:'Registro criado'}:null,
  ].filter(Boolean);
  const cls={create:'hi-cre',edit:'hi-edi',delete:'hi-del'};
  const lbl={create:'➕ Criado',edit:'✏️ Editado',delete:'🗑 Excluído',login:'🔑 Login'};
  document.getElementById('hist-c').innerHTML=!items.length
    ?'<div class="empty"><div class="empty-ico">📋</div><div>Nenhum histórico</div></div>'
    :items.slice(0,30).map(h=>`<div class="hi"><div class="hi-top"><span class="hi-ev ${cls[h.action]||'ae-log'}">${lbl[h.action]||'📌'}</span><span class="hi-ts">${h.timestamp||''}</span></div><div class="hi-desc"><b>${h.user||'—'}</b>${h.login?` (@${h.login})`:''} — ${h.detail||''}</div></div>`).join('');
  openModal('m-hist');
}

// BACKUP
async function exportBackup() {
  toast('Exportando dados...');
  const backup = { version:'3.0', exportedAt:nowStr(), db:DB, unimed:UNIMED, users:USERS, audit:AUDIT };
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(backup,null,2)],{type:'application/json'}));
  a.download=`convenioauth_backup_${new Date().toISOString().slice(0,10)}.json`;
  a.click(); toast('✅ Backup exportado com sucesso!');
}
async function importBackup(input) {
  const file=input.files[0]; if(!file)return;
  if(!confirm('Importar este backup? Os dados existentes serão mantidos — novos registros serão adicionados.'))return;
  try {
    const text=await file.text();
    const data=JSON.parse(text);
    toast('Importando dados...');
    let count=0;
    // Importar meses
    for(const [mes,rows] of Object.entries(data.db||{})){
      for(const r of rows){
        await db.collection(mes).doc(String(r.id)).set(r);
        count++;
      }
    }
    // Importar Unimed
    for(const r of (data.unimed||[])){
      await db.collection('unimed').doc(String(r.id)).set(r);
      count++;
    }
    await pushAudit('create',`Importou backup: ${count} registros`);
    toast(`✅ ${count} registros importados com sucesso!`);
    input.value='';
  } catch(e){toast('Erro ao importar: '+e.message,true);}
}

// AUDITORIA
async function pushAudit(action,detail){
  const entry={action,detail,user:currentUser.fullname,login:currentUser.login,timestamp:nowStr()};
  AUDIT.unshift(entry);
  try{await db.collection('audit').add(entry);}catch(_){}
}

// FILTER/SORT/EXPORT
function setFilter(f){currentFilter=f;render();}
function setConv(c){currentConv=c;render();}
function doSort(k){if(sortKey===k)sortDir*=-1;else{sortKey=k;sortDir=1;}render();}
function exportCSV(){
  const rows=DB[currentTab]||[];
  const csv='Registro,Status,Convênio,Nome,Guia,Obs,CriadoPor,CriadoEm,EditadoPor,EditadoEm\n'+
    rows.map(r=>`${r.registro},"${r.status}","${r.convenio}","${r.nome}","${r.guia||''}","${r.obs||''}","${r.createdBy||''}","${r.createdAt||''}","${r.editedBy||''}","${r.editedAt||''}"`).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
  a.download=`autorizacoes_${currentTab.replace(/ /g,'_')}.csv`;
  a.click(); toast('CSV exportado');
}

// UTILS
function hide(id){const el=document.getElementById(id);if(el)el.style.display='none';}
function show(id,d='block'){const el=document.getElementById(id);if(el)el.style.display=d;}
function showEl(id,msg){const el=document.getElementById(id);if(el){el.textContent=msg;el.classList.add('on');}}
function s(id,val){const el=document.getElementById(id);if(el)el.textContent=val;}
function setTxt(id,val){const el=document.getElementById(id);if(el)el.textContent=val;}
function s2(id,val){const el=document.getElementById(id);if(el)el.value=val;}
function v(id){const el=document.getElementById(id);return el?el.value.trim():'';}
function nowStr(){return new Date().toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});}
function setBL(id,loading,original=''){const btn=document.getElementById(id);if(!btn)return;btn.disabled=loading;if(loading){btn.dataset.orig=btn.textContent;btn.textContent='Salvando...';}else btn.textContent=original||btn.dataset.orig||'Salvar';}
function toast(msg,err=false){const t=document.getElementById('toast');t.textContent=msg;t.className='toast'+(err?' err':'');t.classList.add('on');setTimeout(()=>t.classList.remove('on'),3200);}
</script>
