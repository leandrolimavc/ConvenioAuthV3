function liveSearch(q) {
  q=q.toLowerCase();
  let rows=(DB[currentTab]||[]).filter(r=>{
    if(r.status==='Autorizado'||r.status==='Arquivado') return false;
    if(currentFilter!=='all'&&r.status!==currentFilter) return false;
    if(currentConv!=='Todos'&&r.convenio!==currentConv) return false;
    return!q||(r.registro||'').includes(q)||(r.nome||'').toLowerCase().includes(q)||(r.convenio||'').toLowerCase().includes(q)||(r.guia||'').includes(q)||(r.obs||'').toLowerCase().includes(q);
  });
  if(sortKey) rows.sort((a,b)=>(a[sortKey]||'').localeCompare(b[sortKey]||'','pt-BR')*sortDir);
  const tbody=document.getElementById('tbody');
  if(tbody){tbody.innerHTML=buildRows(rows);s('row-count',`${rows.length} de ${(DB[currentTab]||[]).filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado').length} registros`);}
}

