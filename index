  closeAll();
  try{await fbSaveUnimed(record);await pushAudit(isNew?'create':'edit',`${isNew?'Adicionou':'Editou'} paciente Unimed: ${nome}`);toast(isNew?'✅ Paciente salvo':'✅ Paciente atualizado');}
  catch(e){toast('Erro: '+e.message,true);}
