async function saveAuth() {
  const registro=v('fa-reg'),guia=v('fa-guia'),status=v('fa-st'),convenio=v('fa-cv'),nome=v('fa-nome'),obs=v('fa-obs');
  if(!registro||!nome||!status||!convenio){toast('Preencha os campos obrigatórios (*)',true);return;}
  setBL('btn-sa',true);
  const now=nowStr(); const isNew=!editAuthId; const id=editAuthId||String(nextId++);
  if(!DB[currentTab]) DB[currentTab]=[];
  const record={id,registro,guia,status,convenio,nome,obs,
    createdBy: isNew ? currentUser.login : ((DB[currentTab]||[]).find(x=>String(x.id)===String(editAuthId))||{}).createdBy||currentUser.login,
    createdAt: isNew ? now : ((DB[currentTab]||[]).find(x=>String(x.id)===String(editAuthId))||{}).createdAt||now,
    editedBy: isNew ? '' : currentUser.login,
    editedAt: isNew ? '' : now,
  };
  closeAll();
  try {
    await fbSaveAuth(currentTab, record);
    await pushAudit(isNew?'create':'edit',`${isNew?'Criou':'Editou'} reg. ${registro} — ${nome}`);
    toast(isNew?'✅ Registro criado':'✅ Registro atualizado');
  } catch(e){toast('Erro: '+e.message,true);}
  finally{setBL('btn-sa',false,'💾 Salvar');}
}

async function saveUnimed() {
  const nome=v('fu-nome'),tel=v('fu-tel'),raw=document.getElementById('fu-data').value;
