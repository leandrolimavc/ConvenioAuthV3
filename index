<script>
'use strict';

// ═══════════════════════════════════════════════
// CONFIGURAÇÃO FIREBASE
// ═══════════════════════════════════════════════
const DESTROY_PASS = 'encerrar@2026';

const PRAZOS = {
  'União Médica':10,'Bradesco':2,'Planserv':2,'Plansul':15,
  'Unimed':10,'Geap':5,'SulAmérica':1,'Cassi':2,
  'Promédica':5,'Amil':10,'Vitallis':5,'Asfeb':5,
  'Postal Saúde':5,'SelectSaúde':5,
};

const CONV_CLS = {
  'Amil':'cv-amil','Asfeb':'cv-asfeb','Bradesco':'cv-bradesco','Cassi':'cv-cassi',
  'Geap':'cv-geap','Planserv':'cv-planserv','Plansul':'cv-plansul','Postal Saúde':'cv-postal',
  'Promédica':'cv-promedica','SelectSaúde':'cv-select','SulAmérica':'cv-sulamerica',
  'Unimed':'cv-unimed','União Médica':'cv-uniaomedica','Vitallis':'cv-vitallis',
};

const MESES_KEY   = ['Janeiro','Fevereiro','Marco','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const MESES_LABEL = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

// ═══════════════════════════════════════════════
// ESTADO
// ═══════════════════════════════════════════════
let db = null;
let currentUser = null;
let DB     = {};
let UNIMED = [];
let USERS  = [];
let AUDIT  = [];
let MESES  = [];
let CONFIG = {};
let HISTORY = {};
let unsubscribers = [];

let currentTab    = '';
let currentFilter = 'all';
let currentConv   = 'Todos';
let arquFilter    = 'all';
let arquConv      = 'Todos';
let arquSearch    = '';
let sortKey = ''; let sortDir = 1;
let editAuthId = null; let editUnimedId = null; let editUserId = null;
let nextId = 9000;
let isDark = localStorage.getItem('ca_theme') === 'dark';

// ═══════════════════════════════════════════════
// TEMA
// ═══════════════════════════════════════════════
function applyTheme() {
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  const btn = document.getElementById('theme-btn');
  if (btn) btn.textContent = isDark ? '☀️' : '🌙';
}
function toggleTheme() {
  isDark = !isDark;
  localStorage.setItem('ca_theme', isDark ? 'dark' : 'light');
  applyTheme();
}

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
window.addEventListener('load', () => {
  applyTheme();
  const cfg = loadFbConfig();
  if (!cfg) {
    hide('loading'); showSetup();
    return;
  }
  initFirebase(cfg);
});

function loadFbConfig() {
  const s = localStorage.getItem('ca_fb_config');
  if (!s) return null;
  try { return JSON.parse(s); } catch { return null; }
}

function initFirebase(cfg) {
  try {
    if (firebase.apps.length === 0) {
      firebase.initializeApp(cfg);
    }
    db = firebase.firestore();
    // Testar conexão
    setTxt('load-txt', 'Verificando sistema...');
    db.collection('config').doc('app').get()
      .then(doc => {
        const data = doc.exists ? doc.data() : {};
        if (data.status === 'inativo') {
          showEncerramento(); return;
        }
        hide('loading');
        show('login', 'flex');
      })
      .catch(err => {
        // Firestore pode não ter docs ainda — OK
        hide('loading');
        show('login', 'flex');
      });
  } catch(e) {
    hide('loading'); showSetup();
    setTxt('setup-err', 'Erro ao inicializar Firebase: ' + e.message);
    show('setup-err', 'block');
  }
}

// ═══════════════════════════════════════════════
// SETUP
// ═══════════════════════════════════════════════
function showSetup() {
  hide('loading'); hide('login'); hide('app');
  show('setup-screen', 'flex');
}

async function saveConfig() {
  const cfg = {
    apiKey:            v('cfg-apiKey'),
    authDomain:        v('cfg-authDomain'),
    projectId:         v('cfg-projectId'),
    storageBucket:     v('cfg-storageBucket'),
    messagingSenderId: v('cfg-messagingSenderId'),
    appId:             v('cfg-appId'),
  };
  if (!cfg.apiKey || !cfg.projectId) {
    showEl('setup-err', 'Preencha pelo menos API Key e Project ID.');
    return;
  }
  const btn = document.getElementById('btn-setup');
  btn.disabled = true; btn.textContent = 'Conectando...';
  try {
    if (firebase.apps.length > 0) {
      firebase.apps.forEach(app => app.delete());
    }
    firebase.initializeApp(cfg);
    db = firebase.firestore();
    // Testar
    await db.collection('config').doc('app').set({ status: 'ativo', versao: '3.0' }, { merge: true });
    // Criar usuários padrão
    await setupDefaultUsers();
    localStorage.setItem('ca_fb_config', JSON.stringify(cfg));
    hide('setup-screen');
    show('login', 'flex');
    toast('Firebase configurado! Faça login para começar.');
  } catch(e) {
    showEl('setup-err', 'Erro: ' + e.message + '. Verifique as credenciais e as regras do Firestore.');
  } finally {
    btn.disabled = false; btn.textContent = '🔥 Conectar ao Firebase';
  }
}

async function setupDefaultUsers() {
  const snap = await db.collection('users').get();
  if (!snap.empty) return;
  const now = nowStr();
  const users = [
    { id:'1', fullname:'Fabrício',    login:'fabricio',   password:'fabricio',   role:'admin', color:'#1a56db', createdAt:now },
    { id:'2', fullname:'Leandro',     login:'leandro',    password:'leandro',    role:'admin', color:'#6b21a8', createdAt:now },
    { id:'3', fullname:'Call Center', login:'callcenter', password:'callcenter', role:'user',  color:'#059669', createdAt:now },
  ];
  for (const u of users) {
    await db.collection('users').doc(u.id).set(u);
  }
}

// ═══════════════════════════════════════════════
// LOGIN / LOGOUT
// ═══════════════════════════════════════════════
async function doLogin() {
  const login = v('f-login');
  const pass  = v('f-pass');
  const errEl = document.getElementById('login-err');
  const btn   = document.getElementById('btn-login');
  if (!login || !pass) { errEl.textContent='⚠ Preencha usuário e senha.'; errEl.classList.add('on'); return; }
  btn.disabled = true; btn.textContent = 'Entrando...'; errEl.classList.remove('on');

  try {
    // Verificar status do sistema
    const cfgDoc = await db.collection('config').doc('app').get();
    if (cfgDoc.exists && cfgDoc.data().status === 'inativo') { showEncerramento(); return; }

    // Buscar usuário
    const snap = await db.collection('users').where('login','==',login).where('password','==',pass).get();
    if (snap.empty) throw new Error('Usuário ou senha incorretos');

    currentUser = snap.docs[0].data();
    hide('login');
    show('loading','flex');
    setTxt('load-txt', 'Carregando dados...');
    setTxt('load-sub', 'Conectando em tempo real...');

    await loadAllData();
    await pushAudit('login', 'Fez login no sistema');

    hide('loading');
    show('app','block');
    setTxt('chip-name', currentUser.fullname);
    const rb = document.getElementById('chip-role');
    rb.textContent = currentUser.role === 'admin' ? 'admin' : 'usuário';
    rb.className = 'role-tag' + (currentUser.role==='admin'?' admin':'');

    // Ouvintes em tempo real
    startListeners();
    buildTabs(); render();

  } catch(e) {
    errEl.textContent = '✗ ' + (e.message||'Erro de conexão.');
    errEl.classList.add('on');
  } finally {
    btn.disabled=false; btn.textContent='Entrar no sistema';
  }
}

async function doLogout() {
  await pushAudit('login','Saiu do sistema');
  stopListeners();
  currentUser=null; DB={}; UNIMED=[]; USERS=[]; AUDIT=[]; HISTORY=[];
  hide('app'); show('login','flex');
  s2('f-login',''); s2('f-pass','');
}

// ═══════════════════════════════════════════════
// FIREBASE — CARREGAR DADOS
// ═══════════════════════════════════════════════
async function loadAllData() {
  // Usuários
  const usersSnap = await db.collection('users').get();
  USERS = usersSnap.docs.map(d => d.data());

  // Unimed
  const uniSnap = await db.collection('unimed').orderBy('createdAt','asc').get();
  UNIMED = uniSnap.docs.map(d => d.data());

  // Auditoria (últimos 100)
  try {
    const audSnap = await db.collection('audit').orderBy('timestamp','desc').limit(100).get();
    AUDIT = audSnap.docs.map(d => d.data());
  } catch { AUDIT = []; }

  // Config
  const cfgDoc = await db.collection('config').doc('app').get();
  CONFIG = cfgDoc.exists ? cfgDoc.data() : {};

  // Meses — buscar coleções de autorizações
  const collRef = await db.listCollections();
  const mesCollections = collRef
    .map(c => c.id)
    .filter(id => MESES_KEY.some(m => id.startsWith(m)));

  // Adicionar mês atual se não existir
  const now = new Date();
  const mesAtual = `${MESES_KEY[now.getMonth()]} ${now.getFullYear()}`;
  const todosMeses = [...new Set([...mesCollections, mesAtual])];
  MESES = todosMeses.sort((a,b) => {
    const [ma,ya]=a.split(' '); const [mb,yb]=b.split(' ');
    return ya!==yb ? parseInt(ya)-parseInt(yb) : MESES_KEY.indexOf(ma)-MESES_KEY.indexOf(mb);
  });

  // Carregar dados de cada mês
  for (const mes of MESES) {
    try {
      const snap = await db.collection(mes).orderBy('createdAt','desc').get();
      DB[mes] = snap.docs.map(d => d.data());
    } catch { DB[mes] = []; }
  }

  // Nextid
  const ids = [...Object.values(DB).flat(), ...UNIMED, ...USERS].map(r=>parseInt(r.id)||0);
  nextId = ids.length ? Math.max(...ids)+1 : 9000;

  if (!currentTab || !MESES.includes(currentTab)) currentTab = mesAtual;
}

// ═══════════════════════════════════════════════
// LISTENERS EM TEMPO REAL
// ═══════════════════════════════════════════════
function startListeners() {
  stopListeners();

  // Config (encerramento em tempo real)
  const u1 = db.collection('config').doc('app').onSnapshot(doc => {
    if (doc.exists && doc.data().status === 'inativo') showEncerramento();
  });

  // Unimed
  const u2 = db.collection('unimed').onSnapshot(snap => {
    UNIMED = snap.docs.map(d => d.data());
    updateStats(); buildTabs();
    if (currentTab === 'Unimed Genesy') render();
  });

  // Usuários
  const u3 = db.collection('users').onSnapshot(snap => {
    USERS = snap.docs.map(d => d.data());
    if (currentTab === '⚙ Administração') render();
  });

  // Meses ativos
  MESES.forEach(mes => {
    const u = db.collection(mes).onSnapshot(snap => {
      DB[mes] = snap.docs.map(d => d.data());
      updateStats(); buildTabs();
      if (currentTab === mes || currentTab === '🚨 Urgentes' || currentTab === '✅ Arquivados') render();
    });
    unsubscribers.push(u);
  });

  unsubscribers.push(u1, u2, u3);
}

function stopListeners() {
  unsubscribers.forEach(u => u && u());
  unsubscribers = [];
}

// ═══════════════════════════════════════════════
// FIREBASE — SALVAR / DELETAR
// ═══════════════════════════════════════════════
async function fbSaveAuth(tab, record) {
  await db.collection(tab).doc(String(record.id)).set(record);
}
async function fbDeleteAuth(tab, id) {
