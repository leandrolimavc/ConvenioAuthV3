}
async function fbSetConfig(key, value) {
  await db.collection('config').doc('app').set({ [key]: value }, { merge: true });
}

// ═══════════════════════════════════════════════
// TABS / STATS
// ═══════════════════════════════════════════════
function getMesLabel(key) {
  const idx = MESES_KEY.indexOf(key.split(' ')[0]);
  return idx >= 0 ? `${MESES_LABEL[idx]} ${key.split(' ')[1]}` : key;
}
function tabCount(t) {
  if (t==='Unimed Genesy')   return UNIMED.length;
  if (t==='⚙ Administração') return USERS.length;
  if (t==='🚨 Urgentes')     return getUrgentes().length;
  if (t==='✅ Arquivados')   return getArquivados().length;
  return (DB[t]||[]).filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado').length;
}
function buildTabs() {
  const isAdmin = currentUser?.role==='admin';
  const SPEC = ['🚨 Urgentes','✅ Arquivados','Unimed Genesy'];
  if (isAdmin) SPEC.push('⚙ Administração');
  const ALL = [...MESES, ...SPEC];
  document.getElementById('tabbar').innerHTML = ALL.map(t => {
    const lbl = MESES.includes(t) ? getMesLabel(t) : t;
    const cls = ['tab-item',
      t===currentTab?'active':'',
      t==='🚨 Urgentes'?'tab-urg':'',
      t==='✅ Arquivados'?'tab-arch':'',
    ].filter(Boolean).join(' ');
    return `<div class="${cls}" onclick="goTab('${t}')">${lbl}<span class="tab-count">${tabCount(t)}</span></div>`;
  }).join('');
}
function goTab(t) {
  currentTab=t; currentFilter='all'; currentConv='Todos'; sortKey=''; sortDir=1;
  buildTabs(); render();
}
function updateStats() {
  const all = Object.values(DB).flat();
  s('st-ana', all.filter(r=>r.status==='Análise').length);
  s('st-exi', all.filter(r=>r.status==='Exigência').length);
  s('st-neg', all.filter(r=>r.status==='Negada').length);
  s('st-tot', all.filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado').length);
  s('st-urg', getUrgentes().length);
  s('st-arq', getArquivados().length);
}

// ═══════════════════════════════════════════════
// PRAZO
// ═══════════════════════════════════════════════
function parseDate(raw) {
  if (!raw||typeof raw!=='string') return null;
  raw=raw.trim();
  let m=raw.match(/(\d{2})\/(\d{2})\/(\d{4})/);
  if(m) return new Date(+m[3],+m[2]-1,+m[1]);
  m=raw.match(/(\d{4})-(\d{2})-(\d{2})/);
  if(m) return new Date(+m[1],+m[2]-1,+m[3]);
  const MENS={Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  m=raw.match(/([A-Za-z]{3})\s+(\d{1,2})\s+(\d{4})/);
  if(m){const mo=MENS[m[1]];if(mo!==undefined)return new Date(+m[3],mo,+m[2]);}
  const d=new Date(raw); if(!isNaN(d))return d;
  return null;
}
function addWorkDays(base,days) {
  const d=new Date(base); d.setHours(0,0,0,0);
  let c=0;
  while(c<days){d.setDate(d.getDate()+1);if(d.getDay()!==0&&d.getDay()!==6)c++;}
  return d;
}
function calcPrazo(r) {
  if(r.status!=='Análise') return {status:'sem'};
  const dias=PRAZOS[r.convenio]; if(!dias) return {status:'sem'};
  let base=null;
  for(const src of [r.createdAt,r.data,r.editedAt]){
    base=parseDate(src); if(base&&!isNaN(base))break;
  }
  if(!base||isNaN(base)) base=new Date();
  const dl=addWorkDays(base,dias);
  const hoje=new Date(); hoje.setHours(0,0,0,0); dl.setHours(0,0,0,0);
  const diff=Math.round((dl-hoje)/86400000);
  const st=diff<0?'vencido':diff<=2?'urgente':diff<=4?'alerta':'ok';
  const label=diff<0?`⚠ Vencido há ${Math.abs(diff)}d`:diff===0?'🔴 Vence hoje!':diff<=2?`🔴 ${diff}d úteis`:diff<=4?`🟡 ${diff}d úteis`:`🟢 ${diff}d úteis`;
  return {status:st,label,diff,dias};
}
function prazoBadge(r) {
  const p=calcPrazo(r);
  if(p.status==='sem') return '<span class="pb-sem">—</span>';
  const cls={ok:'pb-ok',alerta:'pb-alt',urgente:'pb-urg',vencido:'pb-vec'}[p.status]||'pb-ok';
  return `<span class="pb ${cls}">${p.label}</span>`;
}

// ═══════════════════════════════════════════════
// URGENTES / ARQUIVADOS
// ═══════════════════════════════════════════════
function getUrgentes() {
  const out=[];
  Object.entries(DB).forEach(([tab,rows])=>{
    (rows||[]).forEach(r=>{
      const p=calcPrazo(r);
      if(['urgente','vencido','alerta'].includes(p.status)) out.push({...r,_tab:tab,_p:p});
    });
  });
  return out.sort((a,b)=>a._p.diff-b._p.diff);
}
function getArquivados() {
  const out=[];
  Object.entries(DB).forEach(([tab,rows])=>{
    (rows||[]).forEach(r=>{ if(r.status==='Autorizado'||r.status==='Arquivado') out.push({...r,_tab:tab}); });
  });
  return out.sort((a,b)=>(b.editedAt||b.createdAt||'').localeCompare(a.editedAt||a.createdAt||''));
}

// ═══════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════
function render() {
  updateStats();
  const m=document.getElementById('main');
  const map={'🚨 Urgentes':renderUrgentes,'✅ Arquivados':renderArquivados,'Unimed Genesy':renderUnimed,'⚙ Administração':renderAdm};
  m.innerHTML=(map[currentTab]||renderMain)();
}

// HELPERS
function badge(st) {
  const map={'Análise':['b-ana','⏳'],'Exigência':['b-exi','⏸'],'Negada':['b-neg','✗'],'Autorizado':['b-aut','✓'],'Arquivado':['b-arq','📁']};
  const[c,i]=map[st]||['b-ana','?'];
  return `<span class="badge ${c}">${i} ${st}</span>`;
}
function cv(c) { return `<span class="cv ${CONV_CLS[c]||'cv-outro'}">${c||'—'}</span>`; }
function rastr(r) {
  if(r.editedBy&&r.editedAt) return `<div class="rastr"><div class="r-lbl r-edi">✏ Editado</div><div class="r-who">${r.editedBy}</div><div class="r-dt">${r.editedAt}</div></div>`;
  return `<div class="rastr"><div class="r-lbl r-cri">✚ Criado</div><div class="r-who">${r.createdBy||'—'}</div><div class="r-dt">${r.createdAt||'—'}</div></div>`;
}
function rowCls(r) {
  const p=calcPrazo(r);
  if(p.status==='vencido') return 'rs-vec';
  if(p.status==='urgente') return 'rs-urg';
  if(r.status==='Análise')   return 'rs-ana';
  if(r.status==='Exigência') return 'rs-exi';
  if(r.status==='Negada')    return 'rs-neg';
  return '';
}
function sa(k) { return sortKey!==k?'<span class="sa">↕</span>':`<span class="sa on">${sortDir===1?'↑':'↓'}</span>`; }

// MAIN TABLE
function getRows() {
  let rows=[...(DB[currentTab]||[])].filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado');
  if(currentFilter!=='all') rows=rows.filter(r=>r.status===currentFilter);
  if(currentConv!=='Todos') rows=rows.filter(r=>r.convenio===currentConv);
  if(sortKey) rows.sort((a,b)=>(a[sortKey]||'').localeCompare(b[sortKey]||'','pt-BR')*sortDir);
  else rows.sort((a,b)=>{const pa=parseDate(a.createdAt||'');const pb=parseDate(b.createdAt||'');return(pb||0)-(pa||0);});
  return rows;
}
function buildRows(rows) {
  const isAdmin=currentUser?.role==='admin';
  if(!rows.length) return `<tr><td colspan="9"><div class="empty"><div class="empty-ico">🔎</div><div>Nenhum registro encontrado</div></div></td></tr>`;
  return rows.map((r,i)=>`
    <tr class="${rowCls(r)}" style="animation-delay:${i*.02}s">
      <td class="num">${r.registro||'—'}</td>
      <td>${badge(r.status)}</td>
      <td>${cv(r.convenio)}</td>
      <td class="nome-c">${r.nome||'—'}</td>
      <td class="num" style="color:var(--muted)">${r.guia||'—'}</td>
      <td>${prazoBadge(r)}</td>
      <td class="obs-c" title="${r.obs||''}">${r.obs||'—'}</td>
      <td>${rastr(r)}</td>
      <td><div class="acts">
        <button class="act" onclick="openAuth('${r.id}')">✏</button>
        <button class="act" onclick="openHist('${r.id}')">🕐</button>
        <button class="act ok" onclick="arquivar('${r.id}')" title="Arquivar">📁</button>
        ${isAdmin?`<button class="act danger" onclick="delAuth('${r.id}')">🗑</button>`:''}
      </div></td>
    </tr>`).join('');
}

function renderMain() {
  const rows=getRows();
  const total=(DB[currentTab]||[]).filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado').length;
  const convs=['Todos',...new Set((DB[currentTab]||[]).filter(r=>r.status!=='Autorizado'&&r.status!=='Arquivado').map(r=>r.convenio).filter(Boolean))].sort((a,b)=>a==='Todos'?-1:a.localeCompare(b,'pt-BR'));
